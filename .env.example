# Copy to .env.local and fill in. All keys live under Karen's own accounts.

# Contact form delivery via Gmail SMTP (sends straight to Karen's inbox).
# 1. The sending Gmail / Google Workspace address (e.g. office@the-remote-admin.com).
GMAIL_USER=office@the-remote-admin.com
# 2. A 16-character Google "App Password" for that account.
#    Requires 2-Step Verification ON, then: Google Account → Security →
#    2-Step Verification → App passwords → create one for "Mail".
GMAIL_APP_PASSWORD=
# 3. Where inquiries land (optional; defaults to GMAIL_USER).
CONTACT_TO_EMAIL=office@the-remote-admin.com

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://the-remote-admin.com
