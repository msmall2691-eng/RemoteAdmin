# Copy to .env.local and fill in. All keys live under Karen's own accounts.

# Resend — contact form delivery. Create the API key while logged in as Karen.
# https://resend.com/api-keys
RESEND_API_KEY=

# Where the quick contact form sends to. Must be a verified Resend sender domain.
CONTACT_TO_EMAIL=office@the-remote-admin.com
CONTACT_FROM_EMAIL=website@the-remote-admin.com

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://the-remote-admin.com
